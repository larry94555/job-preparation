# secrets.env — sensitive values, loaded into the environment by
# utils/load-secrets.mjs. Copy this file to `secrets.env` (which is gitignored)
# and fill in the values you need. Leave a line blank/removed to skip it.
#
#   cp secrets/secrets.env.example secrets/secrets.env
#
# IMPORTANT: values already present in the real environment (your shell, CI
# secrets, the Oracle Cloud instance) are NOT overridden — external config wins.
# So you can commit nothing and inject these at deploy time instead.

# API key for the llama.cpp server. Must match `llama-server --api-key <key>`.
# Generate one with:  node utils/gen-api-key.mjs --write
LLAMA_API_KEY=

# Base URL of the model host (optional; overrides the active backend's base_url).
# e.g. the Oracle Cloud instance:
# LLAMA_BASE_URL=http://165.1.79.248:8080/v1

# Session-signing secret for the web app.  openssl rand -base64 32
AUTH_SECRET=

# Postgres connection string (hosted deploys).
# DATABASE_URL=postgres://user:pass@host:5432/jobprep

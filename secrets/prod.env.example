# prod.env — production secrets/config for the Docker Compose stack.
#
#   cp secrets/prod.env.example secrets/prod.env    # prod.env is gitignored
#   # fill in the values, then on the VM:
#   docker compose -f docker-compose.prod.yml --env-file secrets/prod.env up -d --build
#
# Every value here is injected into the web / worker / db containers by
# docker-compose.prod.yml. Anything left blank falls back to a safe default or
# disables that feature gracefully (e.g. no STRIPE_* → donations show "not
# configured"; no RESEND_API_KEY → sign-up shows "email not enabled").
# NEVER commit the filled-in prod.env — only this *.example template is tracked.

# ---- Database connection (the ONE value the app needs) ------------------
# DATABASE_URL is the only database setting the app itself reads — a standard
# connection string. Two ways to provide it:
#   • Self-host Postgres in this stack (default): keep the line below, and set
#     POSTGRES_PASSWORD (next section) to the SAME password.
#   • Use a managed / already-running database instead: paste ITS connection
#     string here and DELETE the whole "Database provisioning" section below.
DATABASE_URL=postgres://jobprep:CHOOSE_A_DB_PASSWORD@db:5432/jobprep

# ---- Database provisioning (ONLY when self-hosting the db container) -----
# The bundled Postgres container CREATES the database the first time it starts,
# and the Postgres image needs an initial password to do that. You INVENT this
# value now (it is not a secret you fetch), and it must match the password inside
# DATABASE_URL above. Delete this line if DATABASE_URL points at a managed db.
POSTGRES_PASSWORD=CHOOSE_A_DB_PASSWORD
# (POSTGRES_USER / POSTGRES_DB default to "jobprep"; override only if you must.)

# ---- Auth (Auth.js v5) ---------------------------------------------------
# Session-signing secret.  Generate:  openssl rand -base64 32
AUTH_SECRET=
# Public URL of the site (behind Caddy). Until you have a domain, use the VM's
# http URL, e.g. http://<VM-PUBLIC-IP>:3000 — then switch to https://yourdomain.com.
AUTH_URL=
# Comma-separated emails that get the "admin" role.
AUTH_ADMIN_EMAILS=
# Optional one-click OAuth (leave blank to disable). Set BOTH of a pair to enable.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ---- LLM grader (worker → Oracle llama-server) ---------------------------
# llama-server runs on the VM host, OUTSIDE Docker. From the worker container,
# "localhost" is wrong on Linux — use the VM's own IP here.
LLM_BASE_URL=http://<VM-PRIVATE-IP>:8080/v1
# Must match `llama-server --api-key <key>`.  Generate: node utils/gen-api-key.mjs
LLM_API_KEY=
# Optional grader tuning (defaults are fine).
LLM_TIMEOUT_MS=120000
# DEPLOY_ENV=hosted makes the grader use the single Oracle backend and the
# /models page read-only. MODEL_CONFIG_PATH points at the catalog inside the image.
DEPLOY_ENV=hosted
MODEL_CONFIG_PATH=/app/model_configuration.yaml

# ---- Access mode ----------------------------------------------------------
# REQUIRE_SIGNUP: is sign-up + email verification REQUIRED to use the site?
#   true  (default)  — the normal gated site; visitors must sign up.
#   false            — OPEN the whole site to anyone with no sign-up. Everyone
#                      shares one "guest" progress. Use this to validate the site
#                      end-to-end BEFORE setting up an email-sending domain; the
#                      email settings below are then irrelevant. Flip back to true
#                      (and configure email) for real per-user accounts.
REQUIRE_SIGNUP=true

# ---- Email (magic-link sign-up verification) ------------------------------
# Only needed when REQUIRE_SIGNUP=true. Sign-up sends a verification link, so ONE
# transport below must be set or registration is disabled. Both need DATABASE_URL
# (the adapter stores the verification tokens — the transport only DELIVERS the link).
#
# --- Option 1 (recommended on Oracle): SMTP relay ---
# Connects on the SUBMISSION port (587). Oracle blocks outbound port 25 by
# default, but 587 is NOT blocked — so this needs NO port-unblock request.
# For OCI Email Delivery: Identity → Domains → SMTP Credentials (the username
# looks like "ocid1.user...@ocid1.tenancy...", NOT your console login), and the
# host is your region's endpoint, e.g. smtp.email.us-ashburn-1.oci.oraclecloud.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
#
# --- Option 2: Resend (HTTP API) --- used only if no SMTP_* above is set.
# Its onboarding@resend.dev test sender delivers ONLY to your own Resend-account
# address until you verify a domain — a common cause of "no email arrived".
RESEND_API_KEY=
#
# The From address. With OCI Email Delivery this MUST be an Approved Sender on a
# domain you control (e.g. verify@yourdomain.com) with SPF+DKIM published.
EMAIL_FROM=onboarding@resend.dev

# ---- Support + payments --------------------------------------------------
# Any address that RECEIVES email — the Help link + privacy/terms open a mailto to
# it; it is NEVER used to send. A personal or dedicated Gmail works now; switch to
# support@yourdomain.com (forwarded via Cloudflare Email Routing) once you pick a domain.
SUPPORT_EMAIL=you@gmail.com
# Stripe (Test mode until launch). STRIPE_WEBHOOK_SECRET comes from the webhook
# you create in the Stripe dashboard (step F.6).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# prod.env — production secrets/config for the Docker Compose stack.
#
#   cp secrets/prod.env.example secrets/prod.env    # prod.env is gitignored
#   # fill in the values, then on the VM:
#   docker compose -f docker-compose.prod.yml --env-file secrets/prod.env up -d --build
#
# Every value here is injected into the web / worker / db containers by
# docker-compose.prod.yml. Anything left blank falls back to a safe default or
# disables that feature gracefully (e.g. no STRIPE_* → donations show "not
# configured"; no RESEND_API_KEY → sign-up shows "email not enabled").
# NEVER commit the filled-in prod.env — only this *.example template is tracked.

# ---- Database (Postgres container) --------------------------------------
# Pick ONE strong password and use it in BOTH lines — they must match, or the
# app can't connect to the db it just created.
POSTGRES_PASSWORD=change-me-to-a-strong-password
DATABASE_URL=postgres://jobprep:change-me-to-a-strong-password@db:5432/jobprep
# (POSTGRES_USER / POSTGRES_DB default to "jobprep"; override only if you must.)

# ---- Auth (Auth.js v5) ---------------------------------------------------
# Session-signing secret.  Generate:  openssl rand -base64 32
AUTH_SECRET=
# Public URL of the site (behind Caddy). Until you have a domain, use the VM's
# http URL, e.g. http://<VM-PUBLIC-IP>:3000 — then switch to https://yourdomain.com.
AUTH_URL=
# Comma-separated emails that get the "admin" role.
AUTH_ADMIN_EMAILS=
# Optional one-click OAuth (leave blank to disable). Set BOTH of a pair to enable.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ---- LLM grader (worker → Oracle llama-server) ---------------------------
# llama-server runs on the VM host, OUTSIDE Docker. From the worker container,
# "localhost" is wrong on Linux — use the VM's own IP here.
LLM_BASE_URL=http://<VM-PRIVATE-IP>:8080/v1
# Must match `llama-server --api-key <key>`.  Generate: node utils/gen-api-key.mjs
LLM_API_KEY=
# Optional grader tuning (defaults are fine).
LLM_TIMEOUT_MS=120000
# DEPLOY_ENV=hosted makes the grader use the single Oracle backend and the
# /models page read-only. MODEL_CONFIG_PATH points at the catalog inside the image.
DEPLOY_ENV=hosted
MODEL_CONFIG_PATH=/app/model_configuration.yaml

# ---- Email (Resend magic-link sign-in) -----------------------------------
RESEND_API_KEY=
# Until you verify your own domain in Resend, use their test sender (delivers
# only to your own Resend-account email). After verifying: verify@yourdomain.com.
EMAIL_FROM=onboarding@resend.dev

# ---- Support + payments --------------------------------------------------
# Mailbox the Help link + privacy/terms point at (Cloudflare Email Routing).
SUPPORT_EMAIL=support@example.com
# Stripe (Test mode until launch). STRIPE_WEBHOOK_SECRET comes from the webhook
# you create in the Stripe dashboard (step F.6).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

{
  "name": "job-preparation",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "validate": "tsx packages/engine/src/cli.ts validate topics",
    "selfcheck": "tsx packages/engine/src/cli.ts selfcheck topics",
    "preview": "tsx packages/engine/src/cli.ts preview",
    "test": "tsx --test packages/engine/src/grade.test.ts",
    "typecheck": "tsc --noEmit -p packages/schema/tsconfig.json && tsc --noEmit -p packages/engine/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}

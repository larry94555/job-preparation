{
  "name": "job-preparation",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "validate": "tsx packages/engine/src/cli.ts validate topics",
    "selfcheck": "tsx packages/engine/src/cli.ts selfcheck topics",
    "preview": "tsx packages/engine/src/cli.ts preview",
    "begin-lesson": "tsx app/server.ts",
    "resume-lesson": "tsx app/server.ts --continue",
    "meta-eval": "tsx packages/evaluator/src/cli.ts meta-eval topics",
    "eval-gate": "tsx packages/evaluator/src/cli.ts meta-eval topics --threshold 0.7",
    "mastery": "tsx scripts/mastery-index.ts",
    "certify": "npm run validate && npm run selfcheck && npm run typecheck && npm run test && npm run eval-gate",
    "test": "tsx --test packages/engine/src/grade.test.ts packages/evaluator/src/aggregate.test.ts packages/lesson/src/review.test.ts",
    "typecheck": "tsc --noEmit -p packages/schema/tsconfig.json && tsc --noEmit -p packages/engine/tsconfig.json && tsc --noEmit -p packages/lesson/tsconfig.json && tsc --noEmit -p packages/evaluator/tsconfig.json && tsc --noEmit -p packages/sandbox/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}

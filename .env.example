# Postgres connection used by STORE=pg and drizzle-kit. Matches docker-compose.yml.
DATABASE_URL=postgres://jobprep:jobprep@localhost:5432/jobprep

# Which ProgressStore to use: "file" (default, zero-setup, local-first) or "pg".
STORE=file

# Directory for the file store (STORE=file).
PROGRESS_DIR=.progress

# ---- Grader model selection ----
# Deployment environment. "local" (default) offers all local-eligible backends in
# the /models UI. "hosted" forces the single hosted backend (e.g. Oracle Cloud
# llama.cpp) and makes the model config read-only — set this on the deployed app.
DEPLOY_ENV=local
# Base URL of the model host (OpenAI-compatible; Ollama or llama.cpp llama-server).
# Optional: overrides the active backend's base_url from model_configuration.yaml.
# In a hosted deploy, set this to the Oracle instance address.
# LLM_BASE_URL=http://localhost:11434/v1
# Bearer token for a secured llama-server (started with --api-key). Leave unset
# for an open endpoint; when the server is locked down, set this to the same key.
# LLM_API_KEY=your-secret-key
# Which model catalog file governs the backends + primary/secondary grader tiers.
# Defaults to ./model_configuration.yaml (project root). The /models UI reads and
# writes this file. Set it to an absolute path for a hosted/standalone deploy.
MODEL_CONFIG_PATH=model_configuration.yaml
# Grader request tuning (all optional). The grader pins temperature 0 + top_k 1;
# seed + max_tokens make grades reproducible and bound output. Raise the timeout
# for slow CPU boxes.
# LLM_SEED=0
# LLM_MAX_TOKENS=1024
# LLM_TIMEOUT_MS=120000

# ---- Auth.js / NextAuth (Phase 3 hosting: authentication) ----
# Secret used to sign session JWTs. A dev default is baked into web/auth.ts so
# local build/dev works out of the box; ALWAYS set a real value in production
# (e.g. `openssl rand -base64 32`).
AUTH_SECRET=dev-only-insecure-secret-change-me

# Comma-separated emails granted the "admin" role. Everyone else is "user".
AUTH_ADMIN_EMAILS=admin@example.com

# Optional OAuth providers — the local dev-stub credentials sign-in works
# without these. Set both id+secret of a provider to enable its button.
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Postgres connection used by STORE=pg and drizzle-kit. Matches docker-compose.yml.
DATABASE_URL=postgres://jobprep:jobprep@localhost:5432/jobprep

# Which ProgressStore to use: "file" (default, zero-setup, local-first) or "pg".
STORE=file

# Directory for the file store (STORE=file).
PROGRESS_DIR=.progress
